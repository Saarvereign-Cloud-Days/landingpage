---
import { getEntry, render } from 'astro:content';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  dayNumber: 1 | 2 | 3;
  id: string;
}

const { lang, dayNumber, id } = Astro.props;
const t = useTranslations(lang);

const entry = await getEntry('day', `${lang}/day${dayNumber}`);
const { Content } = await render(entry!);
const { title, date, highlights, externalLink, externalLinkLabel } = entry!.data;

const accentColors: Record<number, string> = {
  1: 'border-day1',
  2: 'border-day2',
  3: 'border-day3',
};

const bgColors: Record<number, string> = {
  1: 'bg-day1/5',
  2: 'bg-day2/5',
  3: 'bg-day3/5',
};

const textColors: Record<number, string> = {
  1: 'text-day1',
  2: 'text-day2',
  3: 'text-day3',
};

const isEven = dayNumber % 2 === 0;
---

<section id={id} class:list={['py-20 scroll-mt-16', isEven ? 'bg-accent' : 'bg-surface']}>
  <div class="mx-auto max-w-6xl px-4">
    <div class="mb-8">
      <span class:list={['inline-block rounded-full px-4 py-1 text-sm font-semibold', bgColors[dayNumber], textColors[dayNumber]]}>
        {t('day.label')} {dayNumber}
      </span>
    </div>
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h2 class:list={['text-3xl font-bold md:text-4xl', textColors[dayNumber]]}>
          {title}
        </h2>
        <p class="mt-2 text-lg text-text-muted">{date}</p>
        <div class="mt-6 prose prose-lg max-w-none text-text-muted">
          <Content />
        </div>
        {externalLink && (
          <a
            href={externalLink}
            target="_blank"
            rel="noopener noreferrer"
            class:list={['mt-4 inline-flex items-center gap-1 font-medium hover:underline', textColors[dayNumber]]}
          >
            {externalLinkLabel || externalLink}
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {highlights.map((highlight) => (
          <div class:list={['rounded-lg border-l-4 bg-white p-4 shadow-sm', accentColors[dayNumber]]}>
            <p class="font-medium text-text">{highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
