---
import { languages, type Lang } from '../i18n/ui';
import { getOtherLangUrl } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const otherLang = lang === 'de' ? 'en' : 'de';
const otherUrl = getOtherLangUrl(Astro.url);
---

<a
  href={otherUrl}
  class="rounded-md border border-white/30 px-3 py-1 text-sm font-medium text-white hover:bg-white/10 transition-colors"
>
  {languages[otherLang]}
</a>
