---
import { getEntry, render } from 'astro:content';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const entry = await getEntry('footer', `${lang}/footer`);
const { Content } = await render(entry!);
const { organizer, address, email } = entry!.data;
---

<footer class="border-t border-gray-200 bg-white py-12">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <h3 class="text-lg font-bold text-primary">Sovereign Cloud Days</h3>
        <p class="mt-1 text-sm text-text-muted">Saar-Lor-Lux</p>
        <div class="mt-3 text-sm text-text-muted prose prose-sm">
          <Content />
        </div>
      </div>
      <div>
        <h4 class="font-semibold text-text">{organizer}</h4>
        <p class="mt-2 text-sm text-text-muted">{address}</p>
        <a href={`mailto:${email}`} class="mt-1 inline-block text-sm text-secondary hover:underline">
          {email}
        </a>
      </div>
      <div>
        <div class="flex flex-col gap-2">
          <a href="#" class="text-sm text-text-muted hover:text-primary">{t('footer.imprint')}</a>
          <a href="#" class="text-sm text-text-muted hover:text-primary">{t('footer.privacy')}</a>
          <a href={`mailto:${email}`} class="text-sm text-text-muted hover:text-primary">{t('footer.contact')}</a>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-gray-100 pt-6 text-center">
      <p class="text-xs text-text-muted">{t('footer.copyright')}</p>
    </div>
  </div>
</footer>
