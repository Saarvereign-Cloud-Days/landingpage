---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  disabled?: boolean;
}

const { href = '#', variant = 'primary', disabled = false } = Astro.props;

const baseClasses =
  'inline-flex items-center gap-2 rounded-lg px-6 py-3 font-semibold text-sm transition-colors';

const variantClasses = {
  primary: 'bg-secondary text-white hover:bg-primary-light',
  secondary: 'border-2 border-secondary text-secondary hover:bg-secondary/10',
};

const disabledClasses = 'opacity-50 cursor-not-allowed pointer-events-none';
---

{
  disabled ? (
    <span class:list={[baseClasses, variantClasses[variant], disabledClasses]}>
      <slot />
    </span>
  ) : (
    <a href={href} class:list={[baseClasses, variantClasses[variant]]}>
      <slot />
    </a>
  )
}
